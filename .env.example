# --- Server ---
PORT=8080
NODE_ENV=production

# Comma-separated list of API keys that clients must send in the
# `x-api-key` header to access the middleware. Generate long random strings.
MIDDLEWARE_API_KEYS=replace_with_a_long_random_secret,another_optional_key

# CORS origins (comma-separated). Use * only for quick testing.
CORS_ORIGINS=https://illmedicine.github.io,http://localhost:8080

# --- xAI / Grok ---
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4-fast-non-reasoning
GROK_SYSTEM_PROMPT=You are a concise, helpful assistant. Reply in plain spoken English suitable for text-to-speech.

# --- ElevenLabs ---
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=NQMJRVvPew6HsaebYnZj
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Optional voice settings (0.0 - 1.0)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true

# --- Keep-alive (optional) ---
# Public URL of this service; if set, the server will ping /health every 5 min
# so free-tier hosts (Render, etc.) don't spin it down.
SELF_PING_URL=
SELF_PING_INTERVAL_MS=300000

# --- Raven (Android app) ---
# Comma-separated Google OAuth 2.0 Web client IDs allowed to sign in.
# The Android app sends a Google ID token whose `aud` claim must match one
# of these. Leave empty to skip audience checks (NOT recommended).
GOOGLE_CLIENT_IDS=

# Where to persist user profiles and chat history (JSON file store).
RAVEN_DATA_DIR=.raven-data

